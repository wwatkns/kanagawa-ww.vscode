    "tokenColors": [
        {
            "name": "Comment",
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#828279"
            }
        },
        {
            "name": "Variables",
            "scope": [
                "variable",
                "string constant.other.placeholder"
            ],
            "settings": {
                "foreground": "#D0CAB6"
            }
        },
        {
            "name": "Colors",
            "scope": [
                "constant.other.color"
            ],
            "settings": {
                "foreground": "#FFB066"
            }
        },
        {
            "name": "Invalid",
            "scope": [
                "invalid",
                "invalid.illegal"
            ],
            "settings": {
                "foreground": "#E82424"
            }
        },
        {
            "name": "Storage - Type",
            "scope": [
                "storage.type"
            ],
            "settings": {
                "foreground": "#A78BC7"
            }
        },
        {
            "name": "Storage - Modifier",
            "scope": [
                "storage.modifier"
            ],
            "settings": {
                "foreground": "#A78BC7"
            }
        },
        {
            "name": "Control Keyword",
            "scope": [
                "keyword.control.flow",
                "keyword.control.conditional",
                "keyword.control.loop"
            ],
            "settings": {
                "foreground": "#A78BC7",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Operator, Misc",
