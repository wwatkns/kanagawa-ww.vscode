                "constant.other.color",
                "meta.tag",
                "keyword.other.template",
                "keyword.other.substitution",
                "keyword.other"
            ],
            "settings": {
                "foreground": "#A78BC7"
            }
        },
        {
            "name": "ini file definition",
            "scope": [
                "keyword.other.definition.ini"
            ],
            "settings": {
                "foreground": "#FFB066"
            }
        },
        {
            "name": "Operator, Misc",
